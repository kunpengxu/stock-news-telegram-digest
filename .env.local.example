# Copy this file to .env.local and fill your real values.

GEMINI_API_KEY=your_gemini_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Optional (recommended only if your plan includes Newsfilter Query API)
# NEWSFILTER_API_KEY=your_newsfilter_api_key

GEMINI_MODEL=gemini-1.5-flash
MAX_BULLETS_PER_SECTOR=6
DRY_RUN=false
SEND_FALLBACK_ON_ERROR=false

# Keep true for timezone-safe scheduling (runs only at Beijing 09:00/18:00)
ENABLE_BEIJING_GATE=true
