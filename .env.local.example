# Copy this file to .env.local and fill your real values.

GEMINI_API_KEY=your_gemini_key
ZHIPU_API_KEY=your_zhipu_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Optional (recommended only if your plan includes Newsfilter Query API)
# NEWSFILTER_API_KEY=your_newsfilter_api_key

LLM_PROVIDER=zhipu
GEMINI_MODEL=gemini-2.5-flash
ZHIPU_MODEL=glm-4-flash
ZHIPU_TIMEOUT_SECONDS=120
LLM_MAX_BULLET_CHARS=320
MAX_BULLETS_PER_SECTOR=20
ENFORCE_EXACT_COUNTS=true
DRY_RUN=false
SEND_FALLBACK_ON_ERROR=false

# Keep true for timezone-safe scheduling (runs only at Beijing 09:00/18:00)
ENABLE_BEIJING_GATE=true
